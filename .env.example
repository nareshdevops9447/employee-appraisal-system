# ============================================
# Employee Appraisal System - Environment Variables (Example)
# ============================================

# ---- Database (Monolith) ----
# Format: postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eas_db

# ---- Backend JWT ----
# Generate a secure key: openssl rand -hex 32
JWT_SECRET=changeme_secret_key_must_be_long_and_secure
JWT_ALGORITHM=HS256

# ---- Microsoft Entra ID (Azure AD) ----
AZURE_AD_TENANT_ID=your_azure_tenant_id
AZURE_AD_CLIENT_ID=your_azure_client_id
AZURE_AD_CLIENT_SECRET=your_azure_client_secret

# ---- Frontend Settings ----
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_AZURE_AD_TENANT_ID=your_azure_tenant_id

# Auth (NextAuth)
AUTH_SERVICE_URL=http://localhost:5000/api
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=changeme_different_secret_key_for_nextauth

# ---- Backend Flask Settings ----
FLASK_ENV=development
PORT=5000
